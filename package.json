{
  "name": "pokemon-ssr",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build:browser": "ng build --configuration production",
    "build:server": "ng run pokemon-ssr:server",
    "build": "npm run prerender-routes && npm run build:browser && npm run build:server",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ssr": "node dist/pokemon-ssr/server/server.mjs",
    "prerender-routes": "node scripts/prerender-routes.js"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@netlify/angular-runtime": "^3.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "express": "^5.1.0",
    "postcss": "^8.5.10",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
